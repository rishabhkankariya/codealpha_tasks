# Environment Configuration for Local Development (No Docker)

# Environment
ENVIRONMENT=development

# Database (SQLite for local development)
DATABASE_URL=sqlite:///./smart_bus_pass.db

# Redis (Optional - will work without it)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=dev-secret-key-change-in-production-min-32-characters-long

# OpenAI API (Optional - for AI features later)
OPENAI_API_KEY=

# Azure Storage (Optional - for production only)
AZURE_STORAGE_CONNECTION_STRING=

# Azure Key Vault (Optional - for production only)
KEY_VAULT_URL=

# Application Insights (Optional - for production only)
APPINSIGHTS_INSTRUMENTATION_KEY=
